<Window x:Class="g_mpm.SMTW"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="共享内存调试" Height="600" Width="830"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 状态栏 -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="连接状态:" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtConnectStatus" Text="未初始化" Foreground="Gray" Margin="0,0,30,0"/>
                <TextBlock Text="程序状态:" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtProgramStatus" Text="停止" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- 控制按钮区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnLaunch" Content="启动完整流程" Width="120" Height="30" 
                    Click="BtnLaunch_Click" Background="ForestGreen" Foreground="White" Margin="0,0,10,0"/>
            <Button x:Name="btnStage1" Content="阶段1:初始化内存" Width="130" Height="30" 
                    Click="BtnStage1_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnStage3" Content="阶段3:启动进程" Width="130" Height="30" 
                    Click="BtnStage3_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnStage2" Content="阶段2:等待就绪" Width="130" Height="30" 
                    Click="BtnStage2_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnStage4" Content="阶段4:启动监听" Width="130" Height="30" 
                    Click="BtnStage4_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnShutdown" Content="关闭清理" Width="100" Height="30" 
                    Click="BtnShutdown_Click" Background="DarkRed" Foreground="White"/>
        </StackPanel>

        <!-- 命令发送区 -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="发送命令" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="cmbCommands" Width="150" Margin="0,0,10,0" 
                              ItemsSource="{Binding}" DisplayMemberPath="Key" SelectedValuePath="Value"/>
                    <TextBox x:Name="txtAdditional" Width="200" Margin="0,0,10,0" 
                             Text="附加命令参数"/>
                    <Button x:Name="btnSend" Content="发送命令" Width="100" 
                            Click="BtnSend_Click" Margin="0,0,10,0"/>
                    <Button x:Name="btnSendAndWait" Content="发送并等待回复" Width="120" 
                            Click="BtnSendAndWait_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 日志输出区 -->
        <GroupBox Grid.Row="3" Header="日志输出" Margin="0,0,0,10">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="txtLog" IsReadOnly="True" TextWrapping="Wrap" 
                         FontFamily="Consolas" FontSize="11" Padding="5"
                         VerticalContentAlignment="Top" MinHeight="300"/>
            </ScrollViewer>
        </GroupBox>

        <!-- 回复数据显示区 -->
        <Border Grid.Row="4" Background="#F0F0F0" Padding="10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="最新回复" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="数据类型:" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtReplyType" Text="无" Margin="0,0,30,0"/>
                    <TextBlock Text="数据大小:" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtReplySize" Text="0" Margin="0,0,30,0"/>
                    <TextBlock Text="错误信息:" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtReplyError" Text="无" Foreground="Green"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>