    <None Remove="Resource\OK_Button.png" />
    <None Remove="Resource\Server_tag.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="MPM_ICON.ico" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resource\BackButton.png" />
