            </Image>
            <Image x:Name="GroundSide3" Source="{StaticResource GroundSide}" RenderTransformOrigin="0.5,0.5" Canvas.Top="347.276" Height="209" Canvas.Left="490.313" HorizontalAlignment="Left" VerticalAlignment="Top">
