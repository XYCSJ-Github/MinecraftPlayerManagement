<Window x:Class="g_mpm.IntorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:g_mpm"
        mc:Ignorable="d"
        Title="IntorWindow" Height="500" Width="800">
    <Window.Resources>
        <Storyboard x:Key="AbortIntor" x:Name="BSAI">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle" Storyboard.TargetProperty="(Canvas.Left)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="-80">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:00.9000000" Value="-350">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle1" Storyboard.TargetProperty="(Canvas.Left)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="680">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:00.9000000" Value="950">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle2" Storyboard.TargetProperty="(Canvas.Left)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="-80">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:00.9000000" Value="-350">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle3" Storyboard.TargetProperty="(Canvas.Left)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="677">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:00.9000000" Value="950">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle4" Storyboard.TargetProperty="(Canvas.Top)">
                <SplineDoubleKeyFrame KeyTime="00:00:00.7000000" Value="500">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint2="0.1,1"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="00:00:01.2000000" Value="75">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint2="0.11,1"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rectangle5" Storyboard.TargetProperty="(Canvas.Top)">
                <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="-120">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:00.8000000" Value="-25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="button" Storyboard.TargetProperty="(FrameworkElement.Width)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="160"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.8000000" Value="65">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="button" Storyboard.TargetProperty="(FrameworkElement.Height)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="160"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.8000000" Value="65">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="button" Storyboard.TargetProperty="(FrameworkElement.Margin)">
                <EasingThicknessKeyFrame KeyTime="00:00:00.2000000" Value="0,0,0,90">
                    <EasingThicknessKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="4"/>
                    </EasingThicknessKeyFrame.EasingFunction>
                </EasingThicknessKeyFrame>
                <EasingThicknessKeyFrame KeyTime="00:00:00.9000000" Value="0,0,0,390">
                    <EasingThicknessKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="4"/>
                    </EasingThicknessKeyFrame.EasingFunction>
                </EasingThicknessKeyFrame>
            </ThicknessAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Back" Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:01.1000000" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.5000000" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Back" Storyboard.TargetProperty="(FrameworkElement.Height)">
                <EasingDoubleKeyFrame KeyTime="00:00:01.3000000" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.5000000" Value="40">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseInOut" Power="3"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Canvas x:Name="Side1">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="SideTranslate1" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle" Width="200" Height="400" Fill="White" RenderTransformOrigin="0.5,0.5" Canvas.Left="-80" Canvas.Top="-180">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="0.8" Direction="51" ShadowDepth="10"/>
                </Rectangle.Effect>

                <Rectangle.RenderTransform>
                    <RotateTransform Angle="51"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <Canvas x:Name="Side2">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="SideTranslate2" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle1" Width="200" Height="400" Fill="White" RenderTransformOrigin="0.5,0.5" Canvas.Right="-80" Canvas.Top="-180" Canvas.Left="680">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="0.8" Direction="129" ShadowDepth="10"/>
                </Rectangle.Effect>

                <Rectangle.RenderTransform>
                    <RotateTransform Angle="-51"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <Canvas x:Name="Side3">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="SideTranslate3" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle2" Width="200" Height="400" Fill="White" RenderTransformOrigin="0.5,0.5" Canvas.Left="-80" Canvas.Bottom="-180" Canvas.Top="280">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="0.8" Direction="51" ShadowDepth="10"/>
                </Rectangle.Effect>

                <Rectangle.RenderTransform>
                    <RotateTransform Angle="-51"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <Canvas x:Name="Side4">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="SideTranslate4" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle3" Width="200" Height="400" Fill="White" RenderTransformOrigin="0.5,0.5" Canvas.Right="-80" Canvas.Bottom="-180" Canvas.Left="677" Canvas.Top="280">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="0.8" Direction="129" ShadowDepth="10"/>
                </Rectangle.Effect>

                <Rectangle.RenderTransform>
                    <RotateTransform Angle="51"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <Canvas x:Name="AS">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="AbortSide" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle4" Width="830" Height="500" Fill="White" RenderTransformOrigin="0.5,0.5" Canvas.Top="500" Canvas.Left="-15">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="1" Direction="0" ShadowDepth="10"/>
                </Rectangle.Effect>
            </Rectangle>
        </Canvas>

        <Canvas x:Name="TAS">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="TopSide" Y="0"/>
            </Canvas.RenderTransform>

            <Rectangle x:Name="rectangle5" Width="830" Height="100" Fill="#FFB2DE9A" RenderTransformOrigin="0.5,0.5" Canvas.Bottom="500" Canvas.Left="-15" Canvas.Top="-120">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="70" Opacity="1" Direction="180" ShadowDepth="10"/>
                </Rectangle.Effect>
            </Rectangle>
        </Canvas>



        <!--主按钮-->
        <Button x:Name="button" Width="160" Height="160" BorderBrush="Transparent" Background="Transparent" Margin="0,0,0,90" Click="button_Click">

            <Image x:Name="image" Source="{StaticResource Icon}" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0" RenderTransformOrigin="0.5,0.5">

                <Image.RenderTransform>
                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>

                <Image.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseDown">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.TargetName="IconScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation 
                                    Storyboard.TargetName="IconScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>

                    <EventTrigger RoutedEvent="Mouse.MouseUp">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.TargetName="IconScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="1" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation 
                                    Storyboard.TargetName="IconScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="1" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>

            <Button.Triggers>
                <EventTrigger RoutedEvent="Button.Click">
                    <BeginStoryboard Storyboard="{StaticResource AbortIntor}"/>
                </EventTrigger>
            </Button.Triggers>

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent" />
                    <!-- 也可以移除鼠标悬停效果 -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Button x:Name="Back" Height="40" Width="90" Opacity="0" BorderBrush="Transparent" Background="Transparent" IsEnabled="False" Click="Back_Click" Margin="-660,-390,0,0">
            <Image x:Name="image1" Source="{StaticResource Back_Button}" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Stretch="Fill" Width="90">

                <Image.RenderTransform>
                    <ScaleTransform x:Name="BackScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>

                <Image.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseDown">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.TargetName="BackScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation 
                                    Storyboard.TargetName="BackScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>

                    <EventTrigger RoutedEvent="Mouse.MouseUp">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.TargetName="BackScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation 
                                    Storyboard.TargetName="BackScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="0.9" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <PowerEase Power="3" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>

            <Button.Triggers>
                <EventTrigger RoutedEvent="Button.Click">
                    <BeginStoryboard Storyboard="{StaticResource AbortIntor}"/>
                </EventTrigger>
            </Button.Triggers>
        </Button>

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent" />
                    <!-- 也可以移除鼠标悬停效果 -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>

        </Button>

    </Grid>
</Window>